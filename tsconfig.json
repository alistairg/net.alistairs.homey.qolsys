{
  "extends": "@tsconfig/node16/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "outDir": ".homeybuild/",
    "sourceMap": true,
    "inlineSources": true,
    "sourceRoot": "/",
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["app.ts", "lib/**/*.ts", "drivers/**/*.ts"],
  "exclude": [".homeybuild/**", "node_modules/**", "QolsysController/**", "ha-qolsys-panel/**", "test/**"]
}
